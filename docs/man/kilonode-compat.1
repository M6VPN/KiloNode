.Dd May 27, 2026
.Dt KILONODE-COMPAT 1
.Os
.Sh NAME
.Nm kilonode-compat
.Nd replay KiloNode compatibility lab transcripts
.Sh SYNOPSIS
.Nm
.Cm check-transcript
.Ar path
.Nm
.Cm replay-transcript
.Ar path
.Nm
.Cm replay-dir
.Ar path
.Nm
.Cm report-transcript
.Ar path
.Nm
.Cm check-observation
.Ar path
.Nm
.Cm show-observation
.Ar path
.Nm
.Cm observe-process
.Fl -binary Ar path
.Fl -config Ar path
.Fl -name Ar name
.Fl -mode Ar mode
.Fl -input Ar text
.Fl -output Ar path
.Op Fl -timeout Ar seconds
.Nm
.Cm observe-tcp
.Fl -host Ar host
.Fl -port Ar port
.Fl -name Ar name
.Fl -mode Ar mode
.Fl -input Ar text
.Fl -output Ar path
.Op Fl -timeout Ar seconds
.Nm
.Cm make-transcript-from-observation
.Ar path
.Fl -output Ar path
.Nm
.Cm compare-observations
.Ar left
.Ar right
.Nm
.Cm check-capture
.Ar path
.Nm
.Cm check-pack
.Ar path
.Nm
.Cm decode-capture
.Ar path
.Nm
.Cm replay-capture
.Ar path
.Nm
.Cm replay-capture-dir
.Ar path
.Nm
.Cm capture-report
.Ar path
.Nm
.Cm capture-to-transcript
.Ar path
.Fl -output Ar path
.Nm
.Cm show-pack
.Ar path
.Nm
.Cm pack-report
.Ar path
.Nm
