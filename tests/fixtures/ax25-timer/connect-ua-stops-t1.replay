# KiloNode AX.25 timer replay v1
name connect-ua-stops-t1
node M6VPN-1
remote N0CALL
port kiss0
now 0
params modulo=8 window=1 t1=3000 t2=1000 t3=300000 n2=3
event local-connect
expect prepared-count 1
expect prepared kind=SABM action=send-sabm status=prepared
expect timer-running T1 true
event rx-ua
expect state=connected
expect retry=0
expect prepared-count 1
expect timer-running T1 false
expect timer-running T3 true
expect tx-writes 0
