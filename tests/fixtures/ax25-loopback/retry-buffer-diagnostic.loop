# KiloNode AX.25 loopback script v1
name retry-buffer-diagnostic
endpoint-a M6VPN-1
endpoint-b N0CALL
port kiss0
params modulo=8 window=1 paclen=8 t1=3000 t2=1000 t3=300000 n2=3
event A local-connect
run-until-idle max-steps=8
event A send-i text="retry"
expect A retransmit-buffer=1
expect A retransmit-needed=0
replay-buffer A max-frames=1
expect A retransmit-replayed=1
run-until-idle max-steps=8
expect A state=connected
expect B state=connected
expect A retransmit-acked=1
expect B delivered=1
expect B rejected=1
expect tx-writes 0
expect dispatch-calls 0
expect fx25-frames 0
