# KiloNode AX.25 loopback script v1
name connect-disconnect
endpoint-a M6VPN-1
endpoint-b N0CALL
port kiss0
params modulo=8 window=1 t1=3000 t2=1000 t3=300000 n2=3
event A local-connect
run-until-idle max-steps=8
expect A state=connected
expect B state=connected
event A local-disconnect
run-until-idle max-steps=8
expect A state=disconnected
expect B state=disconnected
expect prepared-count 4
expect transferred 4
expect tx-writes 0
expect dispatch-calls 0
expect fx25-frames 0
