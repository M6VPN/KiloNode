# KiloNode AX.25 loopback script v1
name window-two-segmented
endpoint-a M6VPN-1
endpoint-b N0CALL
port kiss0
params modulo=8 window=2 paclen=3 t1=3000 t2=1000 t3=300000 n2=3
event A local-connect
run-until-idle max-steps=8
event A send-i text="abcdefghij" segment=true
expect A state=connected
expect B state=connected
expect A outstanding=0
expect A outstanding-max=2
expect A acked=4
expect A window-blocked=0
expect B delivered=4
expect B rejected=0
expect B reassembled=1
expect B segment-count=4
expect B last-reassembled-text="abcdefghij"
expect prepared-count 6
expect transferred 10
expect tx-writes 0
expect dispatch-calls 0
expect fx25-frames 0
